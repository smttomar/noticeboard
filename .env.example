# Copy this to .env and fill in your database URL
# TiDB Cloud (recommended - free MySQL-compatible)
DATABASE_URL="mysql://user:password@host:4000/noticeboard?ssl-mode=verify-full"

# Neon (Postgres alternative)
# DATABASE_URL="postgresql://user:password@host/noticeboard?sslmode=require"

# Supabase (Postgres alternative)
# DATABASE_URL="postgresql://postgres:password@db.project.supabase.co:5432/postgres"
